// Harmonia Firebase Storage Security Rules
// Production Privacy-First Storage Access
// CRITICAL: Student recordings are PII of minors under Israeli PDPPA
// Last updated: 2026-03-06 by DBA (production-readiness initiative)
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helper Functions ──
    function isSignedIn() {
      return request.auth != null;
    }

    function isApproved() {
      return isSignedIn() && request.auth.token.approved == true;
    }

    function isTenant(cid) {
      return isApproved() && request.auth.token.conservatoriumId == cid;
    }

    function isAdmin(cid) {
      return isTenant(cid)
        && request.auth.token.role in ['conservatorium_admin', 'delegated_admin', 'site_admin'];
    }

    function isSiteAdmin() {
      return isApproved() && request.auth.token.role == 'site_admin';
    }

    // ── Sheet Music PDFs ──
    // Readable by any enrolled member of the conservatorium
    match /conservatoriums/{cid}/sheetMusic/{compositionId}/{file} {
      allow read: if isTenant(cid);
      allow write: if isTenant(cid)
                   && request.auth.token.role in ['conservatorium_admin', 'teacher']
                   && request.resource.size < 50 * 1024 * 1024 // 50MB max
                   && request.resource.contentType.matches('application/pdf');
    }

    // ── Practice Videos (student-uploaded) ──
    // CRITICAL PII: Video recordings of minors — maximum restriction
    // NO public URLs — signed URLs only via Server Actions
    //
    // PARENT ACCESS: Storage Rules CANNOT call Firestore exists(), so parent-child
    // relationship cannot be verified here. Parents MUST NOT have direct SDK read
    // access. Instead, parents access practice videos through Server Actions that:
    //   1. Verify the parent-child relationship via parentOf/{parentId}_{studentId}
    //   2. Generate a short-lived signed URL (15 min TTL)
    // See: src/app/actions/storage.ts — getSignedPracticeVideoUrl()
    match /conservatoriums/{cid}/practiceVideos/{studentId}/{file} {
      allow read: if isTenant(cid)
                  && (request.auth.uid == studentId
                      || request.auth.token.role in ['conservatorium_admin', 'teacher']);
      allow write: if isApproved()
                   && request.auth.uid == studentId
                   && request.resource.size < 500 * 1024 * 1024 // 500MB max
                   && request.resource.contentType.matches('video/.*');
    }

    // ── Teacher Feedback (audio/video uploaded by teacher for student) ──
    // CRITICAL PII: Recordings may contain minors
    //
    // PARENT ACCESS: Same as practiceVideos — parents MUST NOT have direct SDK
    // read access. Parent access goes through Server Actions with parentOf verification.
    // See: src/app/actions/storage.ts — getSignedFeedbackUrl()
    match /conservatoriums/{cid}/feedback/{studentId}/{logId}/{file} {
      allow read: if isTenant(cid)
                  && (request.auth.uid == studentId
                      || request.auth.token.role in ['conservatorium_admin', 'teacher']);
      allow write: if isTenant(cid)
                   && request.auth.token.role == 'teacher'
                   && request.resource.size < 200 * 1024 * 1024; // 200MB max
    }

    // ── Invoice PDFs ──
    // Generated by Cloud Functions only; readable by admin and payer
    // Signed URLs should be used for parent/student access via Server Actions
    match /conservatoriums/{cid}/invoices/{invoiceId}/{file} {
      allow read: if isTenant(cid)
                  && request.auth.token.role in ['conservatorium_admin', 'parent', 'student'];
      allow write: if false; // Cloud Functions only
    }

    // ── Ministry Form Exports (PDF) ──
    // Sensitive: contains student PII for ministry submissions
    // Signed URLs only via Cloud Functions
    match /conservatoriums/{cid}/formSubmissions/{formId}/{file} {
      allow read: if isTenant(cid)
                  && request.auth.token.role in ['conservatorium_admin', 'ministry_director'];
      allow write: if false; // Cloud Functions only
    }

    // ── Digital Signatures (form signatures) ──
    // PII: Biometric-adjacent data; strict access
    match /conservatoriums/{cid}/signatures/{auditRecordId}/{file} {
      allow read: if isTenant(cid)
                  && request.auth.token.role in ['conservatorium_admin', 'site_admin',
                                                  'ministry_director'];
      allow write: if isApproved()
                   && request.auth.token.conservatoriumId == cid
                   && request.resource.size < 1 * 1024 * 1024 // 1MB max
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Teacher Photos ──
    match /conservatoriums/{cid}/teacherPhotos/{teacherId}/{file} {
      allow read: if isTenant(cid);
      allow write: if isTenant(cid)
                   && (request.auth.uid == teacherId
                       || request.auth.token.role == 'conservatorium_admin')
                   && request.resource.size < 10 * 1024 * 1024 // 10MB max
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Signed Agreements (instrument checkout, rentals) ──
    match /conservatoriums/{cid}/agreements/{checkoutId}/{file} {
      allow read: if isTenant(cid)
                  && request.auth.token.role in ['conservatorium_admin', 'parent'];
      allow write: if false; // Cloud Functions only
    }

    // ── Event Posters (recitals, concerts) ──
    match /conservatoriums/{cid}/events/{eventId}/{file} {
      allow read: if true; // Public — event posters may be shared publicly
      allow write: if isAdmin(cid)
                   && request.resource.size < 20 * 1024 * 1024 // 20MB max
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Conservatorium Logos & Photos ──
    match /conservatoriums/{cid}/branding/{file} {
      allow read: if true; // Public branding assets
      allow write: if isAdmin(cid)
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Profile Photos (user avatars) ──
    match /users/{userId}/avatar/{file} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024 // 5MB max
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Block all other paths ──
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
