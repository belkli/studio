// Harmonia Firestore Security Rules
// SDD-P7 (Security Architect) — Complete RBAC + Data Isolation
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // HELPER FUNCTIONS
    // ============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isApproved() {
      return isSignedIn() && request.auth.token.approved == true;
    }

    function role() {
      return request.auth.token.role;
    }

    function conservatoriumId() {
      return request.auth.token.conservatoriumId;
    }

    function isSiteAdmin() {
      return isApproved() && role() == 'site_admin';
    }

    function isConservatoryAdmin() {
      return isApproved() && role() == 'conservatorium_admin';
    }

    function isAdminFor(cid) {
      return isConservatoryAdmin() && conservatoriumId() == cid;
    }

    function isTeacher() {
      return isApproved() && role() == 'teacher';
    }

    function isTeacherFor(cid) {
      return isTeacher() && conservatoriumId() == cid;
    }

    function isStudent() {
      return isApproved() && role() == 'student';
    }

    function isParent() {
      return isApproved() && role() == 'parent';
    }

    function isMinistryDirector() {
      return isApproved() && role() == 'ministry_director';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Parent-child relationship check (denormalized collection)
    function isParentOfStudent(studentId) {
      return exists(/databases/$(database)/documents/parentOf/$(request.auth.uid + '_' + studentId));
    }

    // ============================================================
    // USER DOCUMENTS
    // ============================================================
    match /users/{userId} {
      allow read: if isOwner(userId)
                  || isSiteAdmin()
                  || isMinistryDirector()
                  || (isAdminFor(resource.data.conservatoriumId))
                  || (isTeacherFor(resource.data.conservatoriumId)
                      && resource.data.role == 'student');
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Users can update their own profile, but NEVER their role or approval status
      allow update: if (isOwner(userId)
                    && !request.resource.data.diff(resource.data).affectedKeys()
                       .hasAny(['role', 'approved', 'conservatoriumId', 'cardToken']))
                    || isAdminFor(resource.data.conservatoriumId)
                    || isSiteAdmin();
    }

    // ============================================================
    // PARENT-CHILD LINKS (denormalized for Security Rules)
    // ============================================================
    match /parentOf/{linkId} {
      allow read: if isSignedIn()
                  && (linkId.matches(request.auth.uid + '_.*')
                      || linkId.matches('.*_' + request.auth.uid));
      allow write: if false; // Cloud Functions only
    }

    // ============================================================
    // CONSERVATORIUM DOCUMENTS
    // ============================================================
    match /conservatoriums/{cid} {
      allow read: if isApproved()
                  && (conservatoriumId() == cid || isMinistryDirector() || isSiteAdmin());
      allow write: if isSiteAdmin() || isAdminFor(cid);

      // ── Settings ──
      match /settings/{settingType} {
        allow read: if isAdminFor(cid) || isSiteAdmin();
        allow write: if isAdminFor(cid) || isSiteAdmin();
      }

      // ── Live Stats ──
      match /stats/live {
        allow read: if isAdminFor(cid) || isSiteAdmin() || isMinistryDirector();
        allow write: if false; // Cloud Functions only
      }

      // ── Lesson Slots ──
      match /lessonSlots/{slotId} {
        allow read: if isAdminFor(cid)
                    || (isTeacherFor(cid) && resource.data.teacherId == request.auth.uid)
                    || (isStudent() && resource.data.studentId == request.auth.uid)
                    || (isParent() && isParentOfStudent(resource.data.studentId))
                    || isMinistryDirector();
        allow create: if isAdminFor(cid) || isTeacherFor(cid);
        allow update: if isAdminFor(cid)
                      || (isTeacherFor(cid) && resource.data.teacherId == request.auth.uid
                          && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['status', 'attendanceMarkedAt', 'teacherNote', 'updatedAt']));
        // Students NEVER write slots directly — must use Cloud Functions
      }

      // ── Lesson Notes (sub-collection of slots) ──
      match /lessonSlots/{slotId}/notes/{noteId} {
        allow read: if isAdminFor(cid)
                    || (isTeacherFor(cid) && resource.data.teacherId == request.auth.uid)
                    || (isStudent() && resource.data.studentId == request.auth.uid
                        && resource.data.isSharedWithStudent == true)
                    || (isParent() && isParentOfStudent(resource.data.studentId)
                        && resource.data.isSharedWithParent == true);
        allow create, update: if isTeacherFor(cid)
                              && request.resource.data.teacherId == request.auth.uid;
      }

      // ── Room Locks ──
      match /roomLocks/{lockKey} {
        allow read: if isAdminFor(cid) || isTeacherFor(cid);
        allow write: if false; // Cloud Functions only (transactional)
      }

      // ── Invoices ──
      match /invoices/{invoiceId} {
        allow read: if isAdminFor(cid)
                    || resource.data.payerId == request.auth.uid
                    || isMinistryDirector();
        allow write: if isAdminFor(cid);
      }

      // ── Makeup Credits ──
      match /makeupCredits/{creditId} {
        allow read: if isAdminFor(cid)
                    || (isStudent() && resource.data.studentId == request.auth.uid)
                    || (isParent() && isParentOfStudent(resource.data.studentId))
                    || isTeacherFor(cid);
        allow write: if false; // Cloud Functions only
      }

      // ── Packages ──
      match /packages/{packageId} {
        allow read: if isAdminFor(cid)
                    || (isStudent() && resource.data.studentId == request.auth.uid)
                    || (isParent() && isParentOfStudent(resource.data.studentId));
        allow write: if isAdminFor(cid);
      }

      // ── Practice Logs ──
      match /practiceLogs/{logId} {
        allow read: if isAdminFor(cid)
                    || (isTeacherFor(cid) && resource.data.teacherId == request.auth.uid)
                    || (isStudent() && resource.data.studentId == request.auth.uid)
                    || (isParent() && isParentOfStudent(resource.data.studentId));
        allow create: if (isStudent() && request.resource.data.studentId == request.auth.uid)
                      || (isParent() && isParentOfStudent(request.resource.data.studentId));
        allow update: if (isTeacherFor(cid)
                          && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['teacherComment', 'teacherCommentedAt']));
      }

      // ── Payroll ──
      match /payrollPeriods/{periodId} {
        allow read: if isAdminFor(cid)
                    || (isTeacherFor(cid) && resource.data.teacherId == request.auth.uid);
        allow write: if isAdminFor(cid);
      }

      // ── Form Submissions ──
      match /formSubmissions/{formId} {
        allow read: if isAdminFor(cid)
                    || resource.data.studentId == request.auth.uid
                    || (isTeacherFor(cid) && resource.data.teacherId == request.auth.uid)
                    || (isParent() && isParentOfStudent(resource.data.studentId))
                    || isMinistryDirector();
        allow create: if isApproved() && conservatoriumId() == cid;
        allow update: if isAdminFor(cid)
                      || (isTeacherFor(cid) && resource.data.teacherId == request.auth.uid
                          && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['teacherComment', 'status', 'teacherDeclaration']))
                      || (isMinistryDirector()
                          && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['status', 'ministryComment', 'ministryReviewedAt',
                                       'ministryReviewedByDirectorId', 'ministryDirectorComment']));
      }

      // ── Scholarship Applications ──
      match /scholarshipApplications/{appId} {
        allow read: if isAdminFor(cid)
                    || resource.data.studentId == request.auth.uid
                    || (isParent() && isParentOfStudent(resource.data.studentId));
        allow create: if (isStudent() && request.resource.data.studentId == request.auth.uid)
                      || (isParent() && isParentOfStudent(request.resource.data.studentId));
        allow update: if isAdminFor(cid);
      }

      // ── Instruments ──
      match /instruments/{instrumentId} {
        allow read: if isApproved() && conservatoriumId() == cid;
        allow write: if isAdminFor(cid);
      }

      // ── Instrument Checkouts ──
      match /instrumentCheckouts/{checkoutId} {
        allow read: if isAdminFor(cid)
                    || resource.data.studentId == request.auth.uid
                    || (isParent() && isParentOfStudent(resource.data.studentId));
        allow write: if isAdminFor(cid);
      }

      // ── Closure Dates ──
      match /closureDates/{dateKey} {
        allow read: if isApproved() && conservatoriumId() == cid;
        allow write: if isAdminFor(cid) || isSiteAdmin();
      }

      // ── Teacher Exceptions (sick leave, etc.) ──
      match /teacherExceptions/{exceptionId} {
        allow read: if isAdminFor(cid)
                    || (isTeacherFor(cid) && resource.data.teacherId == request.auth.uid);
        allow create: if isTeacherFor(cid) && request.resource.data.teacherId == request.auth.uid;
        allow update: if isAdminFor(cid);
      }

      // ── Events ──
      match /events/{eventId} {
        allow read: if isApproved() && conservatoriumId() == cid;
        allow write: if isAdminFor(cid);
      }

      // ── AI Jobs ──
      match /aiJobs/{jobId} {
        allow read: if isApproved() && conservatoriumId() == cid;
        allow write: if false; // Cloud Functions only
      }

      // ── Notifications ──
      match /notifications/{notifId} {
        allow read: if resource.data.userId == request.auth.uid;
        allow write: if false; // Cloud Functions only
      }

      // ── Compliance Logs ──
      match /complianceLogs/{logId} {
        allow read: if isAdminFor(cid) || isSiteAdmin();
        allow write: if false; // Cloud Functions only (append-only)
      }
    }

    // ============================================================
    // CONSENT RECORDS (top-level for PDPPA compliance)
    // ============================================================
    match /consentRecords/{recordId} {
      allow read: if isOwner(resource.data.userId) || isSiteAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // immutable once created; revoke creates new record
    }

    // ============================================================
    // SIGNATURE AUDIT RECORDS
    // ============================================================
    match /signatureAuditRecords/{auditId} {
      allow read: if isAdminFor(resource.data.conservatoriumId) || isSiteAdmin() || isMinistryDirector();
      allow write: if false; // Cloud Functions only (append-only, immutable)
    }

    // ============================================================
    // AGE UPGRADE INVITATIONS
    // ============================================================
    match /ageUpgradeInvitations/{inviteId} {
      allow read: if resource.data.parentId == request.auth.uid
                  || resource.data.studentId == request.auth.uid;
      allow write: if false; // Cloud Functions only
    }
  }
}
