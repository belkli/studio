  "PrivacyPage": {
    "title": "Privacy Statement and Terms of Use",
    "intro": "Harmonia respects your privacy and processes personal data only for clear educational, operational, and legal purposes.",
    "footerLink": "Privacy statement",
    "generalTitle": "General",
    "generalBody": "This policy explains how the site collects, uses, stores, secures, and shares personal data when using Harmonia services.",
    "lawfulBasisTitle": "Legal Basis",
    "lawfulBasisBody": "Data is processed pursuant to the Israeli Privacy Protection Law 5741-1981, contractual necessity, legitimate interests, and consent where required.",
