    "dataItems": {
      "item1": "Identification and contact data such as name, phone, email, and ID number.",
      "item2": "Service data such as lesson history, registrations, attendance, payment and billing information, and requests.",
      "item3": "Technical data such as browser type, device information, and IP address.",
      "item4": "Communication records including support and contact form messages."
    },
    "useTitle": "How We Use Data",
    "useItems": {
      "item1": "Provide requested educational and administrative services, including lesson scheduling and parent notifications.",
      "item2": "Process billing, payments, and financial record-keeping.",
      "item3": "Authenticate users, protect accounts, and prevent abuse.",
      "item4": "Meet legal, accounting, and regulatory obligations."
    },
    "sharingTitle": "Sharing and Processors",
    "sharingBody": "Personal data is shared only with authorized processors and service providers under contractual confidentiality and security obligations. These include Firebase (authentication and hosting), Cardcom (payment processing), and optionally Twilio (SMS notifications).",
    "transfersTitle": "Cross-Border Transfers",
    "transfersBody": "If data is transferred outside Israel, appropriate safeguards are applied according to applicable law.",
    "securityTitle": "Security Controls",
    "securityBody": "We apply access control, encryption in transit where relevant, logging, backups, and operational monitoring. No system can guarantee absolute security.",
    "rightsTitle": "Your Rights",
    "rightsItems": {
      "item1": "Request access to your personal data.",
      "item2": "Request correction of inaccurate or outdated data.",
      "item3": "Request deletion where legally permitted.",
      "item4": "Object to direct marketing communications."
    },
    "retentionTitle": "Retention",
    "retentionBody": "Data is retained only as long as required for service delivery, legal compliance, and audit requirements. Financial records are retained for a minimum of 7 years in accordance with Israeli tax and accounting law.",
